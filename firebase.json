{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "build/web",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{"source": "**", "destination": "/index.html"}],
    "headers": [
      {
        "source": "/index.html",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      },
      {
        "source": "/flutter_bootstrap.js",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      },
      {
        "source": "/flutter_service_worker.js",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      },
      {
        "source": "/version.json",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "mbf-przyjecia",
          "appId": "1:70138421421:android:c977e0d1365af7b5eb6624",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "mbf-przyjecia",
          "configurations": {
            "android": "1:70138421421:android:c977e0d1365af7b5eb6624",
            "ios": "1:70138421421:ios:a4422121caba1982eb6624",
            "web": "1:70138421421:web:fa798be6f39bd353eb6624"
          }
        }
      }
    }
  }
}
